        <visual name="visual"><geometry><box><size>5 0.2 0.6</size></box></geometry><pose>0 0 0.3 0 0 0</pose></visual>
      </link>
    </model>

    <!-- Distributed moving cylinder obstacles (fixed trajectories, LiDAR-detectable) -->
    <model name="moving_cylinder_1">
      <pose>-5.8 -5.4 0 0 0 0</pose>
      <plugin name="moving_cylinder_plugin_1" filename="libobstacle1.so"/>
      <link name="link">
        <kinematic>true</kinematic>
        <collision name="collision"><pose>0 0 0.34 0 0 0</pose><geometry><cylinder><radius>0.26</radius><length>0.68</length></cylinder></geometry></collision>
        <visual name="visual"><pose>0 0 0.34 0 0 0</pose><geometry><cylinder><radius>0.26</radius><length>0.68</length></cylinder></geometry><material><ambient>0.95 0.22 0.22 1.0</ambient><diffuse>0.95 0.22 0.22 1.0</diffuse></material></visual>
      </link>
    </model>

    <model name="moving_cylinder_2">
      <pose>-0.8 -5.8 0 0 0 0</pose>
      <plugin name="moving_cylinder_plugin_2" filename="libobstacle2.so"/>
      <link name="link">
        <kinematic>true</kinematic>
        <collision name="collision"><pose>0 0 0.34 0 0 0</pose><geometry><cylinder><radius>0.25</radius><length>0.68</length></cylinder></geometry></collision>
        <visual name="visual"><pose>0 0 0.34 0 0 0</pose><geometry><cylinder><radius>0.25</radius><length>0.68</length></cylinder></geometry><material><ambient>0.20 0.65 1.00 1.0</ambient><diffuse>0.20 0.65 1.00 1.0</diffuse></material></visual>
