<?xml version="1.0"?>
<sdf version="1.6">
  <world name="goal_seeker_large_dynamic">
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <shadows>false</shadows>
      <ambient>0.45 0.45 0.45 1.0</ambient>
    </scene>

    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>0.0 0.0 24.0 0.0 1.55 0.0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>200</iters>
          <sor>1.4</sor>
        </solver>
      </ode>
    </physics>

    <!-- Outer boundary walls (18m x 18m area) -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 9 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
        </collision>
        <visual name="visual">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static>
      <pose>0 -9 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
        </collision>
        <visual name="visual">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static>
      <pose>9 0 0 0 0 1.5707963</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
        </collision>
        <visual name="visual">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static>
      <pose>-9 0 0 0 0 1.5707963</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
          <pose>0 0 0.3 0 0 0</pose>
        </collision>
        <visual name="visual">
          <geometry><box><size>18 0.2 0.6</size></box></geometry>
