      </link>
    </model>

    <!-- Interior maze walls -->
    <model name="wall_h1">
      <static>true</static>
      <pose>-3.5 -5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>7 0.2 0.6</size></box></geometry><pose>0 0 0.3 0 0 0</pose></collision>
        <visual name="visual"><geometry><box><size>7 0.2 0.6</size></box></geometry><pose>0 0 0.3 0 0 0</pose></visual>
      </link>
    </model>
    <model name="wall_h2">
